{
  "name": "VideoTogether Lite",
  "description": "Sync video playback with friends",
  "version": "3.0.23",
  "manifest_version": 3,
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page.js", "chunks/*.js", "assets/*", "icon/*.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "64": "icon/videotogether-lite_64x64.png",
    "192": "icon/android-icon-192x192.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_icon": {
      "64": "icon/videotogether-lite_64x64.png"
    },
    "default_popup": "popup.html"
  }
}

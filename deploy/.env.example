# Image published by .github/workflows/backend-image.yml.
SERVER_IMAGE=ghcr.io/yicheny0580/videotogetherlite-server:sha-example

# Hostname only, without scheme. DNS A/AAAA records should point here.
BACKEND_DOMAIN=alpha-videotogether.example.com

# Email used by Caddy for ACME account notices.
CADDY_EMAIL=admin@example.com

# Room/participant inactivity window. Keep this aligned with extension behavior.
ROOM_TTL=3m

# The page app runs in arbitrary video-page origins, so the release default is
# broad. Set a comma-separated allow list only if routing requests through a
# stable extension/content-script origin.
ALLOWED_ORIGINS=*
